      {
        "row": 9,
        "col": 0,
        "sizeX": 0,
        "width": 12,
        "title": null,
        "hasTitle": false,
        "message": [
          "%sql",
          "-- Accounts Reached From The Alerted Account",
          "SELECT *",
          "FROM GRAPH_TABLE (",
          "  bank_investigation_graph",
          "  MATCH (a IS account) -[t IS transferred_to]->{1,3} (b IS account)",
          "  WHERE a.account_id = 'A100'",
          "  ONE ROW PER STEP (src, hop, dst)",
          "  COLUMNS (",
          "    vertex_id(src) AS src_id,",
          "    edge_id(hop)   AS hop_id,",
          "    vertex_id(dst) AS dst_id",
          "  )",
          ");"
        ],
        "selectedVisualization": "visualization",
        "visualizationConfig": "[{\"visualization\":{\"height\":365,\"ruleBasedStyles\":[{\"stylingEnabled\":true,\"visibilityEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"style\":{\"dasharray\":\"5\",\"color\":\"rgba(0, 0, 0, 0.1)\"},\"properties\":{\"style\":[\"dashed\"]},\"_id\":1583324064459,\"target\":\"edge\",\"type\":\"styling\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"hiddenConnection\",\"operator\":\"*\",\"value\":\"\"}]},\"component\":\"edge\",\"legendTitle\":\"Hidden Connection\",\"_fromTemplate\":true},{\"_id\":\"-3340ba56\",\"visibilityEnabled\":true,\"stylingEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\",\"value\":\"ACCOUNT\"}]},\"properties\":{\"color\":\"#8FBFD0\",\"label\":{\"text\":\"${properties['ACCOUNT_ID']}\",\"color\":\"rgb(0, 0, 0)\",\"font\":{\"size\":12}}},\"aggregation\":[],\"style\":{\"color\":\"#8FBFD0\",\"label\":{\"text\":\"${properties['ACCOUNT_ID']}\",\"color\":\"rgb(0, 0, 0)\",\"font\":{\"size\":12}}},\"component\":\"vertex\",\"type\":\"styling\",\"target\":\"vertex\",\"isDefaultRule\":true,\"legendTitle\":\"ACCOUNT\"},{\"_id\":1781550220068,\"visibilityEnabled\":true,\"stylingEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"ACCOUNT_ID\",\"operator\":\"=\",\"value\":\"A100\"}]},\"properties\":{\"color\":\"red\"},\"aggregation\":[],\"style\":{\"color\":\"red\"},\"component\":\"vertex\",\"type\":\"styling\",\"target\":\"vertex\",\"isDefaultRule\":false,\"legendTitle\":\"A100\"},{\"_id\":\"24300abc\",\"stylingEnabled\":true,\"visibilityEnabled\":true,\"target\":\"edge\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\",\"value\":\"TRANSFERRED_TO\"}]},\"component\":\"edge\",\"style\":{\"color\":\"#8B8580\"},\"legendTitle\":\"TRANSFE