        "message" : [
          "%pgql-pgx",
          "/* What is the shortest path between cust 6319 and 100344 when only considering SALES, PRODUCTS, and CUSTOMERS and edges between them ",
          "and ignoring the COUNTIRES, i.e. not onisdering the fact they they both are in NL */",
          "SELECT count(e) as NumHops, ",
          "ARRAY_AGG ( label(p)) AS path",
          "from match any shortest (c1:CUSTOMERS) (-[e]-(p:SALES|PRODUCTS|CUSTOMERS))+(c2:CUSTOMERS) on sh_pgview_graph where c1.cust_id=6319 and c2.cust_id=100344"
        ],
