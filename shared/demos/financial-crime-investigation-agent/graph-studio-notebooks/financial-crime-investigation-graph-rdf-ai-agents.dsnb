      {
        "row": 28,
        "col": 0,
        "sizeX": 0,
        "width": 12,
        "title": null,
        "hasTitle": false,
        "message": [
          "%sql",
          "-- What do we actually know about C300? Two raw facts.",
          "SELECT",
          "  RTRIM(LTRIM(p$rdfterm,'<'),'>') AS property,",
          "  RTRIM(LTRIM(o$rdfterm,'<'),'>') AS value",
          "FROM TABLE(SEM_MATCH(",
          "  'PREFIX aml: <http://example.com/aml#>",
          "   SELECT ?p ?o WHERE { aml:C300 ?p ?o . }',",
          "  SEM_MODELS('BANK_RISK_KG'), null,",
          "  null, null, null, ' PLUS_RDFT=VC ', null, null,",
          "  'FINANCIAL_DEMO', 'RDF_NETWORK'",
          "));"
        ],
        "selectedVisualization": "table",
        "visualizationConfig": null,
        "hideCode": false,
