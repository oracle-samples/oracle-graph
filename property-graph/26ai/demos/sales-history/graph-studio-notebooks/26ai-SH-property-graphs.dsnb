          "%pgql-pgx",
          "/* find top 10 customers in NL who bought different products from customer # 1840 and how many such products there are */",
          "select cust.cust_id, count(distinct prod.prod_id) as Num_Products_Not_In_Common from match (cust:CUSTOMERS)<-(s1:SALES)->(prod:PRODUCTS) on sh_pgview_graph ",
          "where not exists (select * from match (c:CUSTOMERS)<-(s:SALES)->(prod:PRODUCTS) on sh_pgview_graph where c.cust_id=1840) ",
          "and cust.country_id = 52770 ",
          "group by cust.cust_id order by Num_Products_Not_In_Common desc limit 20"
        ],
