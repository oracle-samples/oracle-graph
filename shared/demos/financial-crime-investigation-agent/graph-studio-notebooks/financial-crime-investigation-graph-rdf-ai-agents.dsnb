      {
        "row": 39,
        "col": 0,
        "sizeX": 0,
        "width": 12,
        "title": "[Q5] Which customers live in a sanctioned jurisdiction?",
        "hasTitle": true,
        "message": [
          "%sql",
          "",
          "DECLARE",
          "  l_id  VARCHAR2(4000);",
          "  l_res CLOB;",
          "BEGIN",
          "  l_id := DBMS_CLOUD_AI.CREATE_CONVERSATION();",
          "  l_res := DBMS_CLOUD_AI_AGENT.RUN_TEAM(",
          "    team_name   => 'AML_RDF_CASE_TEAM',",
          "    user_prompt => 'Which customers in our database live in a sanctioned jurisdiction?',",
          "    params      => '{\"conversation_id\":\"' || l_id || '\"}'",
          "  );",
          "  DBMS_OUTPUT.PUT_LINE(DBMS_LOB.SUBSTR(l_res, 4000, 1));",
          "END;",
          "/"
        ],
        "selectedVisualization": "raw",
        "visualizationConfig": null,
        "hideCode": false,
        "hideResult": false,
        "hideGutter": true,
        "hideVizConfig": false,
        "hideInIFrame": false,
        "enabled": true,
