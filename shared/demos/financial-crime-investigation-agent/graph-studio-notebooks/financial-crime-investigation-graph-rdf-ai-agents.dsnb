        "title": null,
        "hasTitle": false,
        "message": [
          "%sparql-rdf",
          "PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>",
          "PREFIX aml: <http://example.com/aml#>",
          "CONSTRUCT { ?s ?p ?o }",
          "WHERE {",
          "  ?s ?p ?o .",
          "  FILTER(?s = aml:A300 || ?s = aml:C300 || ?s = aml:XZ)",
          "  FILTER(isIRI(?o))",
          "}"
        ],
