        "hasTitle": true,
        "message": [
          "%md",
          "",
          "# Section 2 - Property Graph",
          "",
          "The property graph exposes transfer paths, shared devices, ownership, and case context as graph patterns."
        ],
        "selectedVisualization": "html",
        "visualizationConfig": null,
        "hideCode": true,
        "hideResult": false,
        "hideGutter": true,
        "hideVizConfig": false,
        "hideInIFrame": false,
        "enabled": true,
        "forms": "[]",
        "result": {
          "interpreter": "md.medium",
