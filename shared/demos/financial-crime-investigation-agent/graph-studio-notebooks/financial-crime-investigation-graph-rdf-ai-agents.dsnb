      {
        "row": 7,
        "col": 0,
        "sizeX": 0,
        "width": 12,
        "title": null,
        "hasTitle": false,
        "message": [
          "%sql",
          "",
          "BEGIN",
          "  BEGIN",
          "    DBMS_CLOUD_AI.DROP_PROFILE(",
          "      profile_name => 'OCI_GENAI_OPENAI',",
          "      force        => TRUE",
          "    );",
          "  EXCEPTION",
          "    WHEN OTHERS THEN NULL;",
          "  END;",
          "",
          "  DBMS_CLOUD_AI.CREATE_PROFILE(",
          "    profile_name => 'OCI_GENAI_OPENAI',",
          "    attributes   => '{",
          "      \"provider\": \"oci\",",
          "      \"credential_name\": \"AI_CREDENTIAL\",",
          "      \"region\": \"<your_oci_region>\",",
          "      \"model\": \"openai.gpt-oss-120b\",",
          "      \"oci_compartment_id\": \"<your_compartment_ocid>\",",
          "      \"object_list\": [",
          "        {\"owner\": \"FINANCIAL_DEMO\", \"name\": \"BANK_INVESTIGATION_GRAPH\"}",
          "      ],",
          "      \"enforce_object_list\": \"true\",",
          "      \"comments\": \"true\",",
          "      \"conversation\": \"true\"",
          "    }',",
          "    description  => 'Profile for chat, NL2SQL, and graph investigation demo'",
          "  );",
          "",
          "  DBMS_CLOUD_AI.SET_PROFILE(profile_name => 'OCI_GENAI_OPENAI');",
          "",
          "  DBMS_OUTPUT.PUT_LINE('OCI_GENAI_OPENAI profile has been successfully created and set.');",
          "END;"
        ],
        "selectedVisualization": "raw",
        "visualizationConfig": null,
