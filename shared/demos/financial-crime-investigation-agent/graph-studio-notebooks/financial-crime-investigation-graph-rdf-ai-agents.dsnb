        "sizeX": 0,
        "width": 12,
        "title": "[VISUAL] RDF graph -- relationships only",
        "hasTitle": false,
        "message": [
          "%sparql-rdf",
          "PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>",
          "PREFIX aml: <http://example.com/aml#>",
          "CONSTRUCT {",
          "  ?s ?p ?o .",
          "}",
          "WHERE {",
          "  ?s ?p ?o .",
          "  FILTER(isIRI(?s) && isIRI(?o))",
          "  FILTER(CONTAINS(STR(?s), 'example.com/aml'))",
          "  FILTER(CONTAINS(STR(?o), 'example.com/aml'))",
          "  FILTER(?p != rdf:type)",
          "}"
        ],
