        "title": "[INFERENCE] C300 WITH OWL2RL -- derived from one fact",
        "hasTitle": false,
        "message": [
          "%sql",
          "-- We only stored: aml:C300 aml:hasResidenceCountry aml:XZ",
          "-- XZ is a SanctionedJurisdiction.",
          "-- OWL2RL rule: hasResidenceCountry some HighRiskJurisdiction => HighRiskCustomer",
          "-- SanctionedJurisdiction subClassOf HighRiskJurisdiction -- so rule fires.",
          "-- HighRiskCustomer subClassOf RequiresEnhancedDueDiligence -- so that follows.",
          "-- None of these labels were typed in. OWL2RL derived all of them.",
          "SELECT RTRIM(REGEXP_REPLACE(class$rdfterm, '^.*#', ''), '>') AS classification",
          "FROM TABLE(SEM_MATCH(",
          "  'PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>",
          "   PREFIX aml: <http://example.com/aml#>",
          "   SELECT ?class WHERE { aml:C300 rdf:type ?class . }',",
          "  SEM_MODELS('BANK_RISK_KG'), SEM_RULEBASES('OWL2RL'),",
          "  null, null, null, ' PLUS_RDFT=VC ', null, null,",
          "  'FINANCIAL_DEMO', 'RDF_NETWORK'",
          "))",
          "WHERE class$rdfterm LIKE '%example.com/aml%'",
          "ORDER BY 1;"
        ],
