        "title" : null,
        "hasTitle" : false,
        "message" : [
          "%pgql-pgx",
          "/* is there a path connecting other customers in NL to customer 1840? i.e. did they buy the same product ",
          "or have a product purchase in common with some other customer who in turn has a purchase in common with cust #1840 and so on */",
          "select count(distinct c2.cust_id) as Num_NL_Customers_Reachable from ",
          "match ANY (c1:CUSTOMERS) (-[e]-(p:SALES|PRODUCTS|CUSTOMERS))+ (c2:CUSTOMERS) on sh_pgview_graph where c1.cust_id=1840 and c2.country_id=52770"
        ],
        "selectedVisualization" : "table",
