        "message" : [
          "%pgql-pgx",
          "",
          "/* Customer who bought the most often and what they bought. Visualize the result */",
          "SELECT c, ecs, s, sp, p ",
          "FROM MATCH (c:CUSTOMERS)<-[ecs]-(s)-[sp]->(p:PRODUCTS) ON SH_PGVIEW_GRAPH ",
          "WHERE c.CUST_ID = (",
          "    SELECT cust.CUST_ID ",
          "    FROM MATCH (cust:CUSTOMERS) ON SH_PGVIEW_GRAPH ",
          "    ORDER BY IN_DEGREE(cust) DESC ",
          "    LIMIT 1",
          ")"
        ],
