        "message": [
          "%sql",
          "SELECT run_aml_sparql(",
          "  'PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>",
          "   PREFIX aml: <http://example.com/aml#>",
          "   SELECT ?entity ?finding",
          "   WHERE {",
          "     ?entity aml:hasResidenceCountry ?country .",
          "     ?country rdf:type aml:SanctionedJurisdiction .",
          "     ?entity rdf:type ?finding .",
          "     FILTER(CONTAINS(STR(?finding), ''example.com/aml''))",
          "   }'",
          ") AS dynamic_result FROM dual;"
        ],
