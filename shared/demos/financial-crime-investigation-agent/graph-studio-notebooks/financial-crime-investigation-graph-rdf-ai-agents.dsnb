      {
        "row": 11,
        "col": 0,
        "sizeX": 0,
        "width": 12,
        "title": null,
        "hasTitle": false,
        "message": [
          "%sql",
          "-- Shared Device Evidence",
          "SELECT *",
          "FROM GRAPH_TABLE (",
          "  bank_investigation_graph",
          "  MATCH (a1 IS account) -[u1 IS used_device]-> (d IS device) <-[u2 IS used_device]- (a2 IS account)",
          "  WHERE a1.account_id = 'A100'",
          "    AND a2.account_id <> a1.account_id",
          "  ONE ROW PER MATCH",
          "  COLUMNS (",
          "    vertex_id(a1) AS a1_id,",
          "    vertex_id(d)  AS device_id,",
          "    vertex_id(a2) AS related_account_id,",
          "    edge_id(u1)   AS a1_device_edge_id,",
          "    edge_id(u2)   AS a2_device_edge_id",
          "  )",
          ");"
        ],
        "selectedVisualization": "visualization",
        "visualizationConfig": "[{\"visualization\":{\"ruleBasedStyles\":[{\"stylingEnabled\":true,\"visibilityEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"style\":{\"dasharray\":\"5\",\"color\":\"rgba(0, 0, 0, 0.1)\"},\"properties\":{\"style\":[\"dashed\"]},\"_id\":1583324064459,\"target\":\"edge\",\"type\":\"styling\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"hiddenConnection\",\"operator\":\"*\",\"value\":\"\"}]},\"component\":\"edge\",\"legendTitle\":\"Hidden Connection\",\"_fromTemplate\":true},{\"_id\":\"-3340ba56\",\"visibilityEnabled\":true,\"stylingEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\",\"value\":\"ACCOUNT\"}]},\"properties\":{\"color\":\"#8FBFD0\",\"label\":{\"text\":\"${properties['ACCOUNT_ID']}\",\"color\":\"black\",\"font\":{\"size\":7.5}}},\"aggregation\":[],\"style\":{\"color\":\"#8FBFD0\",\"label\":{\"text\":\"${properties['ACCOUNT_ID']}\",\"color\":\"black\",\"font\":{\"size\":7.5}}},\"component\":\"vertex\",\"type\":\"styling\",\"target\":\"vertex\",\"isDefaultRule\":true,\"legendTitle\":\"ACCOUNT\"},{\"_id\":\"176d0b81\",\"visibilityEnabled\":true,\"stylingEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\",\"value\":\"DEVICE\"}]},\"properties\":{\"color\":\"#F0CC71\",\"label\":{\"text\":\"${properties['DEVICE_FINGERPRINT']}\",\"color\":\"black\",\"font\":{\"size\":7.5}}},\"aggregation\":[],\"style\":{\"color\":\"#F0CC71\",\"label\":{\"text\":\"${properties['DEVICE_FINGERPRINT']}\",\"color\":\"black\",\"font\":{\"size\":7.5}}},\"component\":\"vertex\",\"type\":\"styling\",\"target\":\"vertex\",\"isDefaultRule\":true,\"legendTitle\":\"DEVICE\"},{\"_id\":\"-44037e28\",\"stylingEnabled\":true,\"visibilityEnabled\":true,\"target\":\"edge\",\"conditions\":{\"ope