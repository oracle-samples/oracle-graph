      {
        "row": 8,
        "col": 0,
        "sizeX": 0,
        "width": 12,
        "title": null,
        "hasTitle": false,
        "message": [
          "%sql",
          "",
          "SELECT *",
          "FROM GRAPH_TABLE (",
          "  bank_investigation_graph",
          "  MATCH (a) -[t]-(b)",
          "  COLUMNS (",
          "    vertex_id(a) AS src_id,",
          "    edge_id(t)   AS hop_id,",
          "    vertex_id(b) AS dst_id",
          "  )",
          ");"
        ],
        "selectedVisualization": "visualization",
        "visualizationConfig": "[{\"visualization\":{\"height\":340,\"ruleBasedStyles\":[{\"stylingEnabled\":true,\"visibilityEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"style\":{\"dasharray\":\"5\",\"color\":\"rgba(0, 0, 0, 0.1)\"},\"properties\":{\"style\":[\"dashed\"]},\"_id\":1583324064459,\"target\":\"edge\",\"type\":\"styling\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"hiddenConnection\",\"operator\":\"*\",\"value\":\"\"}]},\"component\":\"edge\",\"legendTitle\":\"Hidden Connection\",\"_fromTemplate\":true},{\"stylingEnabled\":true,\"visibilityEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"style\":{\"label\":{\"text\":\"${properties['CASE_ID']}\"}},\"properties\":{},\"_id\":1781731310642,\"target\":\"vertex\",\"type\":\"caption\",\"conditions\":{\"conditions\":[{\"property\":\"labels\",\"value\":\"INVESTIGATION_CASE\",\"operator\":\"CONTAINS\"}],\"operator\":\"and\"},\"caption\":{\"id\":1781731310642,\"selectedLabel\":\"INVESTIGATION_CASE\",\"selectedProperty\":\"CASE_ID\"},\"component\":\"vertex\",\"legendTitle\":\"INVESTIGATION_CASE,CASE_ID\"},{\"stylingEnabled\":true,\"visibilityEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"style\":{\"label\":{\"text\":\"${properties['DEVICE_FINGERPRINT']}\"}},\"properties\":{},\"_id\":1781731291696,\"target\":\"vertex\",\"type\":\"caption\",\"conditions\":{\"conditions\":[{\"property\":\"labels\",\"value\":\"DEVICE\",\"operator\":\"CONTAINS\"}],\"operator\":\"and\"},\"caption\":{\"id\":1781731291696,\"selectedLabel\":\"DEVICE\",\"selectedProperty\":\"DEVICE_FINGERPRINT\"},\"component\":\"vertex\",\"legendTitle\":\"DEVICE,DEVICE_FINGERPRINT\"},{\"stylingEnabled\":true,\"visibilityEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"style\":{\"label\":{\"text\":\"${properties['FULL_NAME']}\"}},\"properties\":{},\"_id\":1781731283463,\"target\":\"vertex\",\"type\":\"caption\",\"conditions\":{\"conditions\":[{\"property\":\"labels\",\"value\":\"CUSTOMER\",\"operator\":\"CONTAINS\"}],\"operator\":\"and\"},\"caption\":{\"id\":1781731283463,\"selectedLabel\":\"CUSTOMER\",\"selectedProperty\":\"FULL_NAME\"},\"component\":\"vertex\",\"legendTitle\":\"CUSTOMER,FULL_NAME\"},{\"stylingEnabled\":true,\"visibilityEnabled\":true,\"aggregationEnabled\":true,\"modifierStyles\":{},\"style\":{\"label\":{\"text\":\"${properties['ACCOUNT_ID']}\"}},\"properties\":{},\"_id\":1781731277806,\"target\":\"vertex\",\"type\":\"caption\",\"conditions\":{\"conditions\":[{\"property\":\"labels\",\"value\":\"ACCOUNT\",\"operator\":\"CONTAINS\"}],\"operator\":\"and\"},\"caption\":{\"id\":1781731277806,\"selectedLabel\":\"ACCOUNT\",\"selectedProperty\":\"ACCOUNT_ID\"},\"component\":\"vertex\",\"legendTitle\":\"ACCOUNT,ACCOUNT_ID\"},{\"_id\":\"-3340ba56\",\"stylingEnabled\":true,\"visibilityEnabled\":true,\"target\":\"vertex\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\",\"value\":\"ACCOUNT\"}]},\"component\":\"vertex\",\"style\":{\"color\":\"#8FBFD0\"},\"legendTitle\":\"ACCOUNT\",\"isDefaultRule\":true},{\"_id\":\"-3c1f9907\",\"stylingEnabled\":true,\"visibilityEnabled\":true,\"target\":\"vertex\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\",\"value\":\"CUSTOMER\"}]},\"component\":\"vertex\",\"style\":{\"color\":\"#F0CC71\"},\"legendTitle\":\"CUSTOMER\",\"isDefaultRule\":true},{\"_id\":\"176d0b81\",\"stylingEnabled\":true,\"visibilityEnabled\":true,\"target\":\"vertex\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\",\"value\":\"DEVICE\"}]},\"component\":\"vertex\",\"style\":{\"color\":\"#F7A0A0\"},\"legendTitle\":\"DEVICE\",\"isDefaultRule\":true},{\"_id\":\"-7f7026b6\",\"stylingEnabled\":true,\"visibilityEnabled\":true,\"target\":\"vertex\",\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"labels\",\"operator\":\"CONTAINS\"